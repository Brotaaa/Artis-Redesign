{
  "manifest_version": 3,
  "name": "Artis Login Enhancer",
  "version": "1.9.42",
  "description": "Modernise login + interface interne Artis.net — dark glassmorphism + animations + assistant IA Gilles",
  "permissions": ["storage", "tabs", "notifications"],
  "host_permissions": ["https://generativelanguage.googleapis.com/*"],
  "background": {
    "service_worker": "giles-bg.js"
  },
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    },
    "default_title": "Artis Redesign"
  },
  "web_accessible_resources": [
    {
      "resources": ["justejohn.png"],
      "matches": [
        "*://artis.digithall.org/*",
        "*://*.artis.fr/*",
        "*://*.artis.net/*"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "*://artis.digithall.org/*/composants/login/*",
        "*://*.artis.fr/*/composants/login/*",
        "*://*.artis.net/*/composants/login/*"
      ],
      "js": ["content.js"],
      "css": ["login-override.css"],
      "run_at": "document_end"
    },
    {
      "matches": [
        "*://artis.digithall.org/ArtisWebDigitInvest/*",
        "*://*.artis.fr/*/ArtisWeb*/*",
        "*://*.artis.net/*/ArtisWeb*/*"
      ],
      "exclude_matches": [
        "*://artis.digithall.org/*/composants/login/*",
        "*://*.artis.fr/*/composants/login/*",
        "*://*.artis.net/*/composants/login/*"
      ],
      "js": ["app-content.js", "giles.js"],
      "css": ["app-override.css", "giles.css"],
      "run_at": "document_end"
    }
  ]
}

{
  "manifest_version": 3,
  "name": "Artis Login Enhancer",
  "version": "1.9.43",
  "description": "Modernise login + interface interne Artis.net — dark glassmorphism + animations + assistant IA Gilles",
  "permissions": ["storage", "notifications"],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*",
    "https://artis.digithall.org/*"
  ],
  "background": {
    "service_worker": "giles-bg.js"
  },
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    },
    "default_title": "Artis Redesign"
  },
  "web_accessible_resources": [
    {
      "resources": ["justejohn.png", "fonts/*.woff2"],
      "matches": ["https://artis.digithall.org/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["https://artis.digithall.org/*/composants/login/*"],
      "js": ["content.js"],
      "css": ["fonts/fonts.css", "login-override.css"],
      "run_at": "document_end"
    },
    {
      "matches": ["https://artis.digithall.org/ArtisWebDigitInvest/*"],
      "exclude_matches": ["https://artis.digithall.org/*/composants/login/*"],
      "js": ["app-content.js", "giles.js"],
      "css": ["fonts/fonts.css", "app-override.css", "giles.css"],
      "run_at": "document_end"
    }
  ]
}
